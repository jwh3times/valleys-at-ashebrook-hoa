rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user is an admin if a document with their UID exists in /admins.
    // Create these documents in the Firebase console for each board member.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Announcements: anyone can read; only board admins can create/edit/delete.
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Document metadata (the PDFs themselves live in Cloud Storage).
    match /documents/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Editable site content: dues info, payment options, page text, site config.
    // Stored as singleton documents, e.g. /settings/dues, /settings/site.
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin roster. Readable only by the user it describes (so the admin UI can
    // confirm the signed-in user is a board member). Managed from the Firebase
    // console — clients cannot grant themselves admin rights.
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }
  }
}
