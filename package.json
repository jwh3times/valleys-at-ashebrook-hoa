{
  "name": "valleys-at-ashebrook-hoa",
  "type": "module",
  "version": "0.1.0",
  "description": "Website for the Valleys at Ashebrook HOA",
  "engines": {
    "node": ">=26.4.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "emulators": "firebase emulators:start",
    "deploy": "astro build && firebase deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply ashebrook-hoa --local",
    "db:migrate:remote": "wrangler d1 migrations apply ashebrook-hoa --remote",
    "auth:generate": "npx @better-auth/cli generate --output src/server/db/auth-schema.ts",
    "test:server": "vitest run --config vitest.workers.config.ts",
    "roster:import": "node --experimental-strip-types scripts/import-roster.ts",
    "docs:import": "node --experimental-strip-types scripts/import-documents.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.2",
    "@astrojs/react": "^6.0.0",
    "astro": "^7.0.3",
    "better-auth": "^1.6.23",
    "better-auth-cloudflare": "^0.3.0",
    "drizzle-orm": "^0.45.2",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0",
    "xlsx": "^0.18.5"
  }
}
