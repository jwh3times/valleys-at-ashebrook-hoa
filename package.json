{
  "name": "valleys-at-ashebrook-hoa",
  "type": "module",
  "version": "0.3.0",
  "description": "Resident-run website for The Valleys at Ashebrook",
  "engines": {
    "node": ">=26.4.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "astro build && wrangler deploy -c dist/server/wrangler.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply ashebrook-hoa --local",
    "db:migrate:remote": "wrangler d1 migrations apply ashebrook-hoa --remote",
    "auth:generate": "npx @better-auth/cli generate --output src/server/db/auth-schema.ts",
    "test:server": "vitest run --config vitest.workers.config.ts",
    "roster:import": "node --experimental-strip-types scripts/import-roster.ts",
    "docs:import": "node --experimental-strip-types scripts/import-documents.ts",
    "docs:dedupe": "node --experimental-strip-types scripts/dedupe-documents.ts",
    "corpus:import": "node --experimental-strip-types scripts/import-corpus.ts",
    "ocr:scanned": "node --experimental-strip-types scripts/ocr-scanned.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@astrojs/cloudflare": "^14.1.2",
    "@astrojs/react": "^6.0.1",
    "astro": "^7.0.7",
    "better-auth": "^1.6.23",
    "better-auth-cloudflare": "^0.3.0",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@napi-rs/canvas": "^1.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "pdfjs-dist": "^6.1.200",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.0"
    }
  }
}
