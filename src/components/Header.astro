---
import { navLinks, brandTag } from '../lib/site';
import { DEFAULT_SITE_SETTINGS } from '../lib/types';

const { pathname } = Astro.url;
// Astro.locals.site is set by middleware on every real request; fall back to
// the default so this component is renderable via the Astro Container API too.
const site = Astro.locals.site ?? DEFAULT_SITE_SETTINGS;
const links = navLinks(site.officialMode);
const tag = brandTag(site.officialMode);

const isCurrent = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <a class="brand" href="/">
    <span class="mark mark--lg" aria-hidden="true"><i></i></span>
    <span>
      <span class="brand__name">Valleys at Ashebrook</span>
      <span class="brand__tag">{tag}</span>
    </span>
  </a>

  <button
    class="nav-toggle"
    aria-label="Toggle navigation"
    aria-expanded="false"
  >
    ☰
  </button>

  <div class="nav-cluster">
    <nav class="site-nav" aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isCurrent(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a class="nav-login" href="/admin">Admin sign in</a>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const cluster = document.querySelector('.nav-cluster');
  toggle?.addEventListener('click', () => {
    const open = cluster?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
