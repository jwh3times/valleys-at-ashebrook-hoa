---
const { pathname } = Astro.url;
const links = [
  { href: '/', label: 'Home' },
  { href: '/announcements', label: 'Announcements' },
  { href: '/calendar', label: 'Calendar' },
  { href: '/documents', label: 'Documents' },
  { href: '/dues', label: 'Dues' },
  { href: '/contact', label: 'Contact' },
];

const isCurrent = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <a class="brand" href="/">
    <span class="mark mark--lg" aria-hidden="true"><i></i></span>
    <span>
      <span class="brand__name">Valleys at Ashebrook</span>
      <span class="brand__tag">Homeowners Association</span>
    </span>
  </a>

  <button
    class="nav-toggle"
    aria-label="Toggle navigation"
    aria-expanded="false"
  >
    ☰
  </button>

  <div class="nav-cluster">
    <nav class="site-nav" aria-label="Primary">
      <ul>
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                aria-current={isCurrent(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <a class="nav-login" href="/admin">Board Login</a>
  </div>
</header>

<script>
  const toggle = document.querySelector('.nav-toggle');
  const cluster = document.querySelector('.nav-cluster');
  toggle?.addEventListener('click', () => {
    const open = cluster?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
