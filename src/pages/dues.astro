---
import BaseLayout from '../layouts/BaseLayout.astro';
import DuesInfo from '../components/react/DuesInfo.tsx';
import ConfigNotice from '../components/react/ConfigNotice.tsx';
---

<BaseLayout
  title="Dues"
  description="Annual dues amounts and payment options for the Valleys at Ashebrook HOA."
>
  <div class="page-section">
    <p class="eyebrow">Payments</p>
    <h1 class="page-title" style="margin-bottom: 36px;">
      Dues &amp; Assessments
    </h1>

    <ConfigNotice client:only="react" />
    <DuesInfo client:only="react" />
  </div>
</BaseLayout>
