---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ResetPasswordForm } from '../components/react/AuthForms';
import { NEIGHBORHOOD } from '../lib/site';
---

<BaseLayout
  title="Reset Password"
  description={`Set a new password for your ${NEIGHBORHOOD} resident account.`}
>
  <div class="page-section">
    <p class="eyebrow">Member access</p>
    <h1 class="page-title">Reset Password</h1>
    <p class="page-lead">
      Enter a new password for your account. Reset links expire after one hour.
    </p>
    <ResetPasswordForm client:only="react" />
  </div>
</BaseLayout>
