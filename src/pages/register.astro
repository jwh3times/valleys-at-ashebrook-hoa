---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RegisterForm } from '../components/react/AuthForms';
import { NEIGHBORHOOD } from '../lib/site';
---

<BaseLayout
  title="Create Account"
  description={`Create an account to access resident resources for ${NEIGHBORHOOD}.`}
>
  <div class="page-section">
    <p class="eyebrow">Member access</p>
    <h1 class="page-title">Create Account</h1>
    <p class="page-lead">
      Already have an account? <a href="/login">Sign in</a>. After registering,
      verify your property on the <a href="/verify-property"
        >verify property page</a
      > to unlock homeowner access.
    </p>
    <RegisterForm client:only="react" />
  </div>
</BaseLayout>
