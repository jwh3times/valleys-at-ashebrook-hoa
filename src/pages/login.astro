---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LoginForm } from '../components/react/AuthForms';
---

<BaseLayout
  title="Sign In"
  description="Sign in to your resident account for The Valleys at Ashebrook."
>
  <div class="page-section">
    <p class="eyebrow">Member access</p>
    <h1 class="page-title">Sign In</h1>
    <p class="page-lead">
      Sign in to access homeowner resources. New here? <a href="/register"
        >Create an account</a
      >.
    </p>
    <LoginForm client:only="react" />
  </div>
</BaseLayout>
