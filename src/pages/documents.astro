---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocumentsList from '../components/react/DocumentsList.tsx';
import ConfigNotice from '../components/react/ConfigNotice.tsx';
---

<BaseLayout
  title="Documents"
  description="Governing documents, meeting minutes, financials, and forms for the Valleys at Ashebrook HOA."
>
  <div class="page-section">
    <p class="eyebrow">Reference</p>
    <h1 class="page-title">Governing Documents</h1>
    <p class="page-lead">
      Official documents for the Valleys at Ashebrook community. Click any file
      to download the PDF.
    </p>

    <ConfigNotice client:only="react" />
    <DocumentsList client:only="react" />
  </div>
</BaseLayout>
