---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocumentsList from '../components/react/DocumentsList.tsx';
import { NEIGHBORHOOD } from '../lib/site';
import { env } from 'cloudflare:workers';
import { fetchDocumentsFor } from '../server/content/reads';

// Read tier-filtered documents server-side (SEO / first paint / no-JS). The
// D1 `updatedAt` comes back as a Date; the JSON API path serialized it to an
// ISO string, so match that here to satisfy the DocumentItem contract.
const role = Astro.locals.authContext?.role ?? 'visitor';
const docs = (await fetchDocumentsFor(env, role)).map((d) => ({
  ...d,
  updatedAt: d.updatedAt.toISOString(),
}));
---

<BaseLayout
  title="Documents"
  description={`Governing documents, meeting minutes, financials, and forms for ${NEIGHBORHOOD}.`}
>
  <div class="page-section">
    <p class="eyebrow">Reference</p>
    <h1 class="page-title">Governing Documents</h1>
    <p class="page-lead">
      Documents for the Valleys at Ashebrook community. Click any file to
      download the PDF.
    </p>

    <DocumentsList docs={docs} />
  </div>
</BaseLayout>
