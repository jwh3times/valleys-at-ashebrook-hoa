---
import BaseLayout from '../layouts/BaseLayout.astro';
import { VerifyPropertyForm } from '../components/react/AuthForms';
import { env } from 'cloudflare:workers';

const turnstileSiteKey = env.PUBLIC_TURNSTILE_SITE_KEY;
---

<BaseLayout
  title="Verify Property"
  description="Verify your property ownership to unlock homeowner access."
>
  <div class="page-section">
    <p class="eyebrow">Homeowner access</p>
    <h1 class="page-title">Verify Your Property</h1>
    <p class="page-lead">
      Enter your property address to receive a verification code. Once verified,
      you will have full homeowner access to the site.
    </p>

    <script is:inline>
      window.onTurnstile = function (token) {
        window.turnstileToken = token;
      };
    </script>

    {
      turnstileSiteKey ? (
        <>
          <script
            src="https://challenges.cloudflare.com/turnstile/v0/api.js"
            is:inline
            async
            defer
          />
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-callback="onTurnstile"
          />
          <VerifyPropertyForm client:only="react" />
        </>
      ) : (
        <div class="form-message form-message--error">
          Property verification is temporarily unavailable. Please try again
          later.
        </div>
      )
    }
  </div>
</BaseLayout>
