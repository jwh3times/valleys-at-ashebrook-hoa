# Copy this file to ".env" and fill in the values.
# Everything here is exposed to the browser (Astro only ships PUBLIC_* vars to
# the client). That is fine for the Web3Forms key — security is enforced by
# Cloudflare D1/R2 access controls, not by hiding these values.

# --- Public Google Calendar ---
# The calendar's ID (Google Calendar > Settings > "Integrate calendar" >
# Calendar ID). Often looks like xxxxx@group.calendar.google.com.
PUBLIC_GOOGLE_CALENDAR_ID=
# Optional: the timezone used by the embedded calendar.
PUBLIC_GOOGLE_CALENDAR_TIMEZONE=America/New_York

# --- Contact form (Web3Forms) ---
# Free access key from https://web3forms.com (tied to the HOA Gmail address).
PUBLIC_WEB3FORMS_KEY=
