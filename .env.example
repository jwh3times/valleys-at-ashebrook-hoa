# Copy this file to `.env.local` and fill in the values you need.
# Every variable is OPTIONAL — the site runs without them, gracefully degrading
# (the contact form logs to the console; the dues page shows a "coming soon"
# notice) until you add the relevant keys.

# ---------------------------------------------------------------------------
# Contact form email delivery (Resend — https://resend.com)
# ---------------------------------------------------------------------------
# Without RESEND_API_KEY, submitted messages are logged to the server console.
RESEND_API_KEY=
# Where contact messages are delivered. Defaults to the email in src/lib/site.ts.
CONTACT_TO_EMAIL=
# A verified Resend sender address. Defaults to onboarding@resend.dev for testing.
CONTACT_FROM_EMAIL=

# ---------------------------------------------------------------------------
# Online dues payments (Stripe — https://stripe.com)
# ---------------------------------------------------------------------------
# Without STRIPE_SECRET_KEY, the /dues page shows a "payments not configured"
# notice instead of a pay button. Use a test key (sk_test_...) while developing.
STRIPE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Site URL (used to build Stripe success/cancel redirect links)
# ---------------------------------------------------------------------------
# Set this to your deployed domain, e.g. https://www.maplewoodhills.org
NEXT_PUBLIC_SITE_URL=http://localhost:3000
