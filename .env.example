# Copy this file to ".env" and fill in the values.
# Everything here is exposed to the browser (Astro only ships PUBLIC_* vars to
# the client). That is fine for Firebase web config and the Web3Forms key —
# security is enforced by Firestore/Storage rules, not by hiding these values.

# --- Firebase web app config ---
# Firebase console > Project settings > General > "Your apps" > Web app > Config
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# --- Public Google Calendar ---
# The calendar's ID (Google Calendar > Settings > "Integrate calendar" >
# Calendar ID). Often looks like xxxxx@group.calendar.google.com.
PUBLIC_GOOGLE_CALENDAR_ID=
# Optional: the timezone used by the embedded calendar.
PUBLIC_GOOGLE_CALENDAR_TIMEZONE=America/New_York

# --- Contact form (Web3Forms) ---
# Free access key from https://web3forms.com (tied to the HOA Gmail address).
PUBLIC_WEB3FORMS_KEY=

# --- Local development only ---
# Set to "true" to point the app at the Firebase Emulator Suite (npm run emulators).
PUBLIC_USE_EMULATORS=false
