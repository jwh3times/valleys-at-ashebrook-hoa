# Server-side secrets only. PUBLIC_* build-time vars belong in .env, not here
# (a PUBLIC_* var in .dev.vars shadows .env at build time and hides the real value).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:4321
EMAIL_API_KEY=
EMAIL_FROM=board@example.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TURNSTILE_SECRET_KEY=
# Board-only AI document assistant (admin panel); leave blank to disable it locally.
ANTHROPIC_API_KEY=
